---
import CommentsPanel from "@/components/CommentsPanel.astro";
import { formatDate } from "@/lib/format";
import Base from "./Base.astro";

interface Props {
	slug: string;
	title: string;
	description?: string;
	image?: string;
	canonicalUrl?: string;
	publishedAt?: string;
	authorName?: string;
	categoryName?: string;
}

const {
	slug,
	title,
	description,
	image,
	canonicalUrl,
	publishedAt,
	authorName,
	categoryName,
} = Astro.props;

const formattedDate = publishedAt ? formatDate(publishedAt) : null;
---

<Base title={title} description={description} image={image} canonicalUrl={canonicalUrl}>
	<article class="article-shell">
		<header class="article-hero glass-panel" transition:name={`card-${slug}`}>
			<a href="/blog" class="article-back">返回归档</a>
			<div class="article-kicker">精选文章</div>
			<h1 class="article-title" transition:name={`title-${slug}`}>{title}</h1>
			{description && (
				<p class="article-summary" transition:name={`summary-${slug}`}>
					{description}
				</p>
			)}
			<div class="pill-row" transition:name={`meta-${slug}`}>
				{formattedDate && <time class="pill" datetime={publishedAt}>{formattedDate}</time>}
				{authorName && <span class="pill">{authorName}</span>}
				{categoryName && <span class="pill">{categoryName}</span>}
			</div>
		</header>
		<div class="article-body glass-panel">
			<div class="prose article-prose">
				<slot />
			</div>
		</div>
		<CommentsPanel />
	</article>
</Base>

<style>
	.article-shell {
		display: grid;
		gap: var(--space-xl);
	}

	.article-hero,
	.article-body {
		padding: clamp(1.4rem, 1rem + 2vw, 2.5rem);
	}

	.article-hero {
		display: grid;
		gap: 1rem;
	}

	.article-back {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		padding: 0.58rem 0.92rem;
		border-radius: var(--radius-pill);
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.12);
		color: var(--color-text-secondary);
		font-size: 0.88rem;
		backdrop-filter: blur(10px) saturate(120%);
		-webkit-backdrop-filter: blur(10px) saturate(120%);
	}

	.article-kicker {
		font-size: 0.82rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.article-title {
		font-size: clamp(2.4rem, 1.8rem + 2vw, 4.4rem);
		line-height: 1.02;
		letter-spacing: -0.05em;
	}

	.article-summary {
		max-width: 42rem;
		font-size: 1.04rem;
		line-height: 1.9;
		color: var(--color-text-secondary);
	}

	.article-body {
		margin-inline: auto;
		width: 100%;
	}

	.article-prose {
		margin-inline: auto;
	}
</style>
