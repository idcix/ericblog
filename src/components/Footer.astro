---
import { siteConfig } from "@/lib/types";

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="container">
		<div class="footer-inner glass-panel">
			<div class="footer-copy">
				<p class="footer-title">{siteConfig.name}</p>
				<p class="footer-note">
					把工程经验、调试记录和长期有效的判断慢慢沉淀下来。
				</p>
			</div>
			<p class="footer-meta">© {year} · {siteConfig.author}</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		padding-top: var(--space-xl);
		margin-top: auto;
	}

	.footer-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: var(--space-lg);
		align-items: center;
		padding: 1.2rem 1.4rem;
	}

	.footer-copy {
		display: grid;
		gap: 0.32rem;
	}

	.footer-title {
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-text);
	}

	.footer-note,
	.footer-meta {
		font-size: 0.9rem;
		color: var(--color-text-muted);
	}

	@media (max-width: 860px) {
		.footer-inner {
			grid-template-columns: 1fr;
			justify-items: center;
			text-align: center;
		}
	}
</style>
