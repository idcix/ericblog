---
import { siteConfig } from "@/lib/types";

const commentsConfig = siteConfig.comments;
const isCommentConfigReady = Boolean(
	commentsConfig.repo &&
		commentsConfig.repoId &&
		commentsConfig.category &&
		commentsConfig.categoryId,
);
---

<section
	class="comments-panel glass-panel"
	data-comments-panel
	data-comments-ready={isCommentConfigReady ? "true" : "false"}
	data-comments-provider={commentsConfig.provider}
	data-comments-repo={commentsConfig.repo}
	data-comments-repo-id={commentsConfig.repoId}
	data-comments-category={commentsConfig.category}
	data-comments-category-id={commentsConfig.categoryId}
	data-comments-mapping={commentsConfig.mapping}
	data-comments-strict={commentsConfig.strict ? "1" : "0"}
	data-comments-reactions-enabled={commentsConfig.reactionsEnabled ? "1" : "0"}
	data-comments-input-position={commentsConfig.inputPosition}
	data-comments-lang={commentsConfig.lang}
>
	<button
		class="comments-toggle"
		type="button"
		aria-expanded="false"
		aria-controls="comments-panel-body"
		data-comments-toggle
	>
		<span class="comments-toggle-copy">
			<strong>评论区</strong>
			<small>默认折叠，点开后再加载 GitHub Discussions 喵</small>
		</span>
		<span class="comments-toggle-icon" aria-hidden="true">+</span>
	</button>

	<div
		id="comments-panel-body"
		class="comments-body"
		hidden
		data-comments-body
	>
		{isCommentConfigReady ? (
			<div class="comments-surface">
				<div class="comments-note">
					<p>评论会通过 GitHub Discussions 加载喵</p>
				</div>
				<div class="comments-host" data-giscus-host></div>
			</div>
		) : (
			<div class="comments-empty-state">
				<p>评论组件已经接好了喵</p>
				<p>还差在 GitHub 仓库里开启 Discussions，并回填分类 ID 后才能真正发评论喵</p>
				<p>当前仓库：{commentsConfig.repo}</p>
			</div>
		)}
	</div>
</section>

<script is:inline src="/comments.js"></script>

<style>
	.comments-panel {
		display: grid;
		gap: 0;
		overflow: hidden;
	}

	.comments-toggle {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
		width: 100%;
		padding: 1.05rem 1.2rem;
		border: none;
		background: transparent;
		color: inherit;
		cursor: pointer;
		text-align: left;
	}

	.comments-toggle-copy {
		display: grid;
		gap: 0.2rem;
	}

	.comments-toggle-copy strong {
		font-size: 1rem;
		color: var(--color-text);
	}

	.comments-toggle-copy small {
		font-size: 0.86rem;
		color: var(--color-text-muted);
		line-height: 1.65;
	}

	.comments-toggle-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.12);
		border: 1px solid rgba(255, 255, 255, 0.12);
		font-size: 1.2rem;
		color: var(--color-accent-hover);
		transition:
			transform var(--transition),
			background-color var(--transition),
			border-color var(--transition);
	}

	.comments-panel.is-open .comments-toggle-icon {
		transform: rotate(45deg);
	}

	.comments-body {
		padding: 0 1.2rem 1.2rem;
	}

	.comments-surface,
	.comments-empty-state {
		display: grid;
		gap: 0.9rem;
		padding: 1rem;
		border-radius: var(--radius-inner);
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(12px) saturate(120%);
		-webkit-backdrop-filter: blur(12px) saturate(120%);
	}

	.comments-note,
	.comments-empty-state {
		font-size: 0.92rem;
		color: var(--color-text-muted);
		line-height: 1.75;
	}

	.comments-host {
		min-height: 8rem;
	}

	.comments-panel.is-open .comments-toggle:hover .comments-toggle-icon {
		background: var(--color-accent-soft);
		border-color: rgba(10, 132, 255, 0.16);
	}

	@media (max-width: 640px) {
		.comments-toggle,
		.comments-body {
			padding-inline: 1rem;
		}
	}
</style>
