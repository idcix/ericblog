---
import { formatDate } from "@/lib/format";
import { siteConfig } from "@/lib/types";

interface Props {
	title: string;
	slug: string;
	excerpt?: string | null;
	publishedAt?: string | null;
	categoryName?: string | null;
	authorName?: string | null;
}

const { title, slug, excerpt, publishedAt, categoryName, authorName } =
	Astro.props;

const formattedDate = publishedAt ? formatDate(publishedAt) : null;
---

<article class="post-card glass-panel" transition:name={`card-${slug}`}>
	<div class="post-card-top">
		<div class="pill-row" transition:name={`meta-${slug}`}>
			{formattedDate && <time class="pill" datetime={publishedAt ?? undefined}>{formattedDate}</time>}
			{categoryName && <span class="pill">{categoryName}</span>}
		</div>
		<a href={`/blog/${slug}`} class="post-card-link">
			<h2 class="post-card-title" transition:name={`title-${slug}`}>{title}</h2>
		</a>
	</div>
	{excerpt && (
		<p class="post-card-excerpt" transition:name={`summary-${slug}`}>
			{excerpt}
		</p>
	)}
	<div class="post-card-meta">
		<span>{authorName || siteConfig.author}</span>
		<a href={`/blog/${slug}`} class="post-card-readmore">继续阅读</a>
	</div>
</article>

<style>
	.post-card {
		position: relative;
		display: grid;
		gap: var(--space-md);
		padding: clamp(1.2rem, 1rem + 1vw, 1.8rem);
		opacity: 0;
		animation: post-card-settle 720ms cubic-bezier(0.22, 1, 0.36, 1) both;
		transition:
			transform var(--transition),
			border-color var(--transition),
			box-shadow var(--transition),
			background-color var(--transition);
	}

	.post-card::after {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background:
			linear-gradient(
				125deg,
				rgba(255, 255, 255, 0) 18%,
				rgba(255, 255, 255, 0.18) 48%,
				rgba(255, 255, 255, 0) 72%
			);
		opacity: 0;
		transform: translate3d(-22%, 0, 0);
		transition:
			opacity 280ms ease,
			transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
		pointer-events: none;
	}

	.post-card:hover {
		transform: translate3d(0, -4px, 0) scale(1.004);
		border-color: rgba(10, 132, 255, 0.14);
		background: rgba(255, 255, 255, 0.2);
		box-shadow:
			0 22px 38px -34px rgba(8, 18, 34, 0.22),
			0 8px 18px -16px rgba(8, 18, 34, 0.16);
	}

	.post-card:hover::after {
		opacity: 1;
		transform: translate3d(18%, 0, 0);
	}

	.post-card-top {
		display: grid;
		gap: var(--space-md);
	}

	.pill-row,
	.post-card-title,
	.post-card-excerpt,
	.post-card-meta,
	.post-card-readmore {
		transition:
			transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
			color 220ms ease,
			letter-spacing 220ms ease,
			opacity 220ms ease;
	}

	.post-card-link {
		color: inherit;
	}

	.post-card-title {
		font-size: clamp(1.32rem, 1.2rem + 0.55vw, 1.75rem);
		color: var(--color-text);
		line-height: 1.14;
		letter-spacing: -0.03em;
	}

	.post-card-link:hover .post-card-title {
		color: var(--color-accent-hover);
	}

	.post-card:hover .post-card-title {
		color: var(--color-accent-hover);
	}

	.post-card-excerpt {
		color: var(--color-text-secondary);
		font-size: 0.98rem;
		line-height: 1.8;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-card:hover .post-card-excerpt {
		color: var(--color-text);
	}

	.post-card-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
		font-size: 0.88rem;
		color: var(--color-text-muted);
	}

	.post-card-readmore {
		color: var(--color-accent);
		font-weight: 600;
	}

	@keyframes post-card-settle {
		from {
			opacity: 0;
			filter: blur(10px);
		}

		to {
			opacity: 1;
			filter: blur(0);
		}
	}

	@media (max-width: 640px) {
		.post-card-meta {
			flex-wrap: wrap;
		}
	}

	@media (hover: hover) and (pointer: fine) {
		.post-card:hover {
			transform: translate3d(0, -10px, 0) scale(1.01);
			border-color: rgba(10, 132, 255, 0.18);
			box-shadow:
				0 30px 48px -34px rgba(8, 18, 34, 0.26),
				0 10px 24px -18px rgba(8, 18, 34, 0.18);
		}

		.post-card:hover .pill-row {
			transform: translate3d(0, -2px, 0);
		}

		.post-card:hover .post-card-title {
			letter-spacing: -0.015em;
			transform: translate3d(2px, 0, 0);
		}

		.post-card:hover .post-card-excerpt {
			transform: translate3d(0, 2px, 0);
		}

		.post-card:hover .post-card-meta {
			transform: translate3d(0, 3px, 0);
		}

		.post-card:hover .post-card-readmore {
			transform: translate3d(4px, 0, 0);
		}
	}

	@media (hover: none), (pointer: coarse) {
		.post-card:hover {
			transform: none;
			box-shadow: var(--shadow-card);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.post-card,
		.post-card::after,
		.pill-row,
		.post-card-title,
		.post-card-excerpt,
		.post-card-meta,
		.post-card-readmore {
			animation: none;
			transition: none;
			transform: none;
			opacity: 1;
		}
	}
</style>
