---
import "@/styles/post-card.css";
import { formatDate } from "@/lib/format";
import { siteConfig } from "@/lib/types";

interface Props {
	title: string;
	slug: string;
	excerpt?: string | null;
	publishedAt?: string | null;
	categoryName?: string | null;
	authorName?: string | null;
	featuredImageKey?: string | null;
	featuredImageAlt?: string | null;
	cjkCharCount?: number;
	latinWordCount?: number;
	estimatedReadingMinutes?: number;
	coverSide?: "left" | "right";
}

const {
	title,
	slug,
	excerpt,
	publishedAt,
	categoryName,
	authorName,
	featuredImageKey,
	featuredImageAlt,
	cjkCharCount,
	latinWordCount,
	estimatedReadingMinutes,
	coverSide = "left",
} = Astro.props;

const formattedDate = publishedAt ? formatDate(publishedAt) : null;
const coverImageUrl = featuredImageKey ? `/media/${featuredImageKey}` : null;
const coverImageAlt = featuredImageAlt?.trim() || `${title} 的封面图`;
const hasCover = Boolean(coverImageUrl);
const cardClassName = [
	"post-card",
	"glass-panel",
	hasCover
		? coverSide === "right"
			? "post-card-cover-right"
			: "post-card-cover-left"
		: "post-card-no-cover",
].join(" ");
const safeCjkCharCount =
	Number.isFinite(cjkCharCount) && Number(cjkCharCount) > 0
		? Math.trunc(Number(cjkCharCount))
		: 0;
const safeLatinWordCount =
	Number.isFinite(latinWordCount) && Number(latinWordCount) > 0
		? Math.trunc(Number(latinWordCount))
		: 0;
const safeEstimatedReadingMinutes =
	Number.isFinite(estimatedReadingMinutes) &&
	Number(estimatedReadingMinutes) > 0
		? Math.trunc(Number(estimatedReadingMinutes))
		: 1;
const countLabelParts: string[] = [];

if (safeCjkCharCount > 0) {
	countLabelParts.push(`${safeCjkCharCount.toLocaleString("zh-CN")} 字`);
}

if (safeLatinWordCount > 0) {
	countLabelParts.push(`${safeLatinWordCount.toLocaleString("en-US")} 词`);
}

const articleLengthLabel =
	countLabelParts.length > 0 ? countLabelParts.join(" / ") : "0 字";
const articleReadingTimeLabel = `约 ${safeEstimatedReadingMinutes.toLocaleString("zh-CN")} 分钟`;
---

<article class={cardClassName}>
	{hasCover && (
		<a href={`/blog/${slug}`} class="post-card-cover">
			<img src={coverImageUrl} alt={coverImageAlt} loading="lazy" decoding="async" />
		</a>
	)}
	<div class="post-card-content">
		<div class="post-card-top">
			<div class="pill-row" transition:name={`meta-${slug}`}>
				{formattedDate && (
					<time
						class="pill local-time-pending"
						datetime={publishedAt ?? undefined}
						data-local-time="date"
					>
						{formattedDate}
					</time>
				)}
				{categoryName && <span class="pill">{categoryName}</span>}
				<span class="pill">{articleLengthLabel}</span>
				<span class="pill">{articleReadingTimeLabel}</span>
			</div>
			<a href={`/blog/${slug}`} class="post-card-link">
				<h2 class="post-card-title" transition:name={`title-${slug}`}>{title}</h2>
			</a>
		</div>
		{excerpt && (
			<p class="post-card-excerpt" transition:name={`summary-${slug}`}>
				{excerpt}
			</p>
		)}
		<div class="post-card-meta">
			<span>{authorName || siteConfig.author}</span>
			<a href={`/blog/${slug}`} class="post-card-readmore">继续阅读</a>
		</div>
	</div>
</article>
