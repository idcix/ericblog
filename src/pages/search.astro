---
import SearchBox from "@/components/Search.astro";
import { blogCategories, blogTags } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { sanitizeSlug } from "@/lib/security";

const query = Astro.url.searchParams.get("q")?.trim() || "";
const rawSelectedCategory =
	Astro.url.searchParams.get("category")?.trim().toLowerCase() || "";
const selectedCategory = sanitizeSlug(rawSelectedCategory) || "";
const selectedTags = [
	...new Set(
		Astro.url.searchParams
			.getAll("tags")
			.map((item) => sanitizeSlug(item))
			.filter((item): item is string => Boolean(item)),
	),
];
const hasSearchCriteria = Boolean(
	query || selectedCategory || selectedTags.length > 0,
);

let categories: Array<{ slug: string; name: string }> = [];
let tags: Array<{ slug: string; name: string }> = [];

try {
	const { env } = Astro.locals.runtime;
	const db = getDb(env.DB);
	const [allCategories, allTags] = await Promise.all([
		db
			.select({ slug: blogCategories.slug, name: blogCategories.name })
			.from(blogCategories)
			.orderBy(blogCategories.name),
		db
			.select({ slug: blogTags.slug, name: blogTags.name })
			.from(blogTags)
			.orderBy(blogTags.name),
	]);

	categories = allCategories;
	tags = allTags;
} catch {
	// D1 未绑定时回退为空选项
}

const activeFilters = [
	query ? `关键词：${query}` : "",
	selectedCategory ? `分类：${selectedCategory}` : "",
	selectedTags.length > 0 ? `标签：${selectedTags.join("、")}` : "",
].filter(Boolean);
---

<Base title="搜索" description="使用 Pagefind 在浏览器本地检索文章内容">
	<section
		class="search-hero search-hero-depth glass-panel"
		data-tilt-card
		data-tilt-scale="0.42"
		data-tilt-shift-scale="0.72"
	>
		<span class="section-kicker">站内检索</span>
		<h1 class="page-title">搜索</h1>
		<p class="page-intro">
			本页搜索由 Pagefind 在浏览器内执行，不依赖服务端检索 API。
		</p>
		<div class="search-entry-stage" transition:name="search-entry">
			<SearchBox
				initialQuery={query}
				categories={categories}
				tags={tags}
				selectedCategory={selectedCategory}
				selectedTags={selectedTags}
			/>
		</div>
	</section>

	<section class="search-results-block">
		<div class="section-head">
			<div>
				<h2 class="section-heading">搜索结果</h2>
				<p class="section-subheading">
					{activeFilters.length > 0 ? activeFilters.join(" · ") : "输入关键词后开始检索"}
				</p>
			</div>
			<p id="pagefind-results-summary" class="results-summary">
				{hasSearchCriteria ? "正在加载搜索结果..." : "输入关键词或筛选条件后开始搜索"}
			</p>
		</div>
		<div id="pagefind-search-results" class="search-grid" />
	</section>

	<script is:inline type="module" src="/pagefind-search.js"></script>
</Base>

<style>
	.search-hero {
		--glass-panel-opacity: calc(var(--hero-card-opacity, 14) / 100);
		--glass-panel-blur: var(--hero-card-blur, 18px);
		display: grid;
		gap: 1rem;
		padding: clamp(1.5rem, 1rem + 2vw, 2.6rem);
	}

	.search-hero-depth {
		position: relative;
		overflow: hidden;
		transform:
			perspective(1200px)
			rotateX(var(--tilt-rotate-x, 0deg))
			rotateY(var(--tilt-rotate-y, 0deg))
			scale3d(1.002, 1.002, 1.002);
		transform-style: preserve-3d;
		transition:
			transform var(--nav-motion-surface),
			box-shadow var(--nav-motion-surface);
	}

	.search-hero-depth::before {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background:
			radial-gradient(
				circle at 18% 24%,
				rgba(10, 132, 255, 0.22),
				transparent 38%
			),
			linear-gradient(
				135deg,
				rgba(255, 255, 255, 0.16),
				rgba(255, 255, 255, 0.02) 58%,
				transparent
			);
		opacity: 0.72;
		pointer-events: none;
		transform: translate3d(
			calc(var(--tilt-shift-x, 0) * -8px),
			calc(var(--tilt-shift-y, 0) * -8px),
			0
		);
		transition: transform var(--nav-motion-surface);
	}

	.search-hero-depth .section-kicker,
	.search-hero-depth .page-title,
	.search-hero-depth .page-intro {
		position: relative;
		z-index: 1;
		transform: translate3d(
			calc(var(--tilt-shift-x, 0) * 2px),
			calc(var(--tilt-shift-y, 0) * 2px),
			14px
		);
		transition: transform var(--nav-motion-surface);
	}

	.search-results-block {
		display: grid;
		gap: 1.2rem;
	}

	.search-entry-stage {
		width: 100%;
	}

	.search-hero-depth .search-entry-stage {
		position: relative;
		z-index: 1;
		transform: translate3d(
			calc(var(--tilt-shift-x, 0) * 4px),
			calc(var(--tilt-shift-y, 0) * 4px),
			24px
		);
		transition: transform var(--nav-motion-surface);
	}

	.section-head {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
	}

	.results-summary {
		color: var(--color-text-muted);
		font-size: 0.92rem;
	}

	.search-grid {
		display: grid;
		gap: 1rem;
	}

	:global(.search-result-card) {
		display: grid;
		gap: 0.75rem;
		padding: clamp(0.75rem, 0.56rem + 0.75vw, 1.05rem);
		background-color: rgba(var(--card-surface-rgb), 0.2);
		backdrop-filter: blur(24px) saturate(150%);
		-webkit-backdrop-filter: blur(24px) saturate(150%);
		border: 1px solid rgba(var(--card-border-rgb), 0.24);
		transition:
			transform var(--transition),
			border-color var(--transition),
			box-shadow var(--transition);
	}

	:global(.search-result-card:hover) {
		transform: translate3d(0, -4px, 0);
		border-color: rgba(10, 132, 255, 0.26);
		box-shadow:
			0 24px 34px -30px rgba(8, 18, 34, 0.45),
			0 10px 20px -18px rgba(8, 18, 34, 0.28);
	}

	:global(.search-result-card-inner) {
		display: grid;
		gap: 0.72rem;
	}

	:global(.search-result-pill-row) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	:global(.search-result-pill) {
		display: inline-flex;
		align-items: center;
		height: 1.7rem;
		padding: 0 0.72rem;
		border-radius: 999px;
		background: rgba(var(--card-sheen-rgb), 0.22);
		color: var(--color-text-muted);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	:global(.search-result-link) {
		color: inherit;
		text-decoration: none;
	}

	:global(.search-result-title) {
		margin: 0;
		font-size: clamp(1.2rem, 1.08rem + 0.46vw, 1.54rem);
		line-height: 1.24;
		letter-spacing: -0.02em;
		overflow-wrap: anywhere;
		color: var(--color-text);
	}

	:global(.search-result-link:hover .search-result-title) {
		color: var(--color-accent-hover);
	}

	:global(.search-result-excerpt) {
		margin: 0;
		color: var(--color-text-secondary);
		font-size: 0.96rem;
		line-height: 1.7;
		overflow-wrap: anywhere;
	}

	:global(.search-result-meta) {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.65rem;
		color: var(--color-text-muted);
		font-size: 0.86rem;
	}

	:global(.search-result-readmore) {
		margin-left: auto;
		color: var(--color-accent);
		font-weight: 600;
		text-decoration: none;
	}

	:global(.search-result-readmore:hover) {
		color: var(--color-accent-hover);
	}

	@media (max-width: 840px) {
		.section-head {
			flex-direction: column;
			align-items: start;
		}
	}

	@media (hover: none), (pointer: coarse) {
		.search-hero-depth,
		.search-hero-depth::before,
		.search-hero-depth .section-kicker,
		.search-hero-depth .page-title,
		.search-hero-depth .page-intro,
		.search-hero-depth .search-entry-stage {
			transform: none;
		}
	}
</style>
